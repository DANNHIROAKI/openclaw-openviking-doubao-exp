# Required
VOLCANO_ENGINE_API_KEY=your_volcengine_api_key_here

# Optional; generated automatically if omitted
OPENCLAW_GATEWAY_TOKEN=

# OpenClaw Gateway must use provider/model on OpenClaw 2026.4.14.
# Keep this aligned with `openclaw models list --provider volcengine-plan --all --plain`.
OPENCLAW_PRIMARY_MODEL_REF=arkapi/doubao-seed-2.0-code

# Judge defaults. The bundle keeps judge settings fixed across all three groups.
# By default it reuses the same Volcengine key and the Coding Plan model name doubao-seed-2.0-code.
JUDGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
JUDGE_API_KEY=
JUDGE_MODEL=doubao-seed-2.0-code

# Optional: override storage/tooling locations
EXP_WORKSPACE_ROOT=
OPENCLAW_CLI_PREFIX=
OPENVIKING_TOOL_VENV=

# Optional: filters for debugging / partial reruns
EXP_SAMPLE_FILTER=
EXP_GROUP_FILTER=
EXP_RERUNS=1
EXP_SKIP_SMOKE=0
EXP_KEEP_RUNS=0
EXP_RESUME=1
EXP_SUMMARY_RERUN=1

# Optional: bootstrap toggles
EXP_FORCE_RECLONE=0
EXP_FORCE_REBOOTSTRAP=0

# No-OV ingest quiet wait (milliseconds) after reset before QA begins
EXP_NOOV_QUIET_WAIT_MS=3000

# OpenViking runtime install mode: auto (wheel, then source fallback), wheel, or source
EXP_OPENVIKING_INSTALL_MODE=auto
