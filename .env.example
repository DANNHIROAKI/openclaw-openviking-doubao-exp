# OpenViking × OpenClaw LoCoMo10 Experiment
# Formal baseline env derived from the user's current Ark project resources.

# Volcano Ark API Key (project: OpenClaw-OpenViking-Test)
VOLCANO_ENGINE_API_KEY=ark-91262a19-a9f4-495d-baf5-bc0d74dd4848-8941f

# Ark custom inference endpoints
ARK_LLM_ENDPOINT_ID=ep-20260416162446-48fvm
ARK_EMBEDDING_ENDPOINT_ID=ep-20260417020931-wp6ls

# Force OpenClaw's primary model route to the exact Ark endpoint above.
OPENCLAW_PRIMARY_MODEL_REF=arkapi/ep-20260416162446-48fvm

# Local OpenClaw Gateway auth token (local only; arbitrary but fixed is convenient)
OPENCLAW_GATEWAY_TOKEN=ocgw-openviking-locomo10-20260416

# Judge settings: keep fixed and route to the same Ark endpoint for consistency.
JUDGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
JUDGE_API_KEY=ark-91262a19-a9f4-495d-baf5-bc0d74dd4848-8941f
JUDGE_MODEL=ep-20260416162446-48fvm

# Optional fallback if the embedding endpoint itself ever behaves oddly.
# In that case, comment out ARK_EMBEDDING_ENDPOINT_ID above and uncomment the next line.
# ARK_EMBEDDING_MODEL=doubao-embedding-vision-251215

# Workspace / tooling locations
EXP_WORKSPACE_ROOT=./workspace
OPENCLAW_CLI_PREFIX=./cache/tooling/openclaw-cli
OPENVIKING_TOOL_VENV=./cache/tooling/openviking-venv

# Formal experiment defaults
EXP_RERUNS=1
EXP_SKIP_SMOKE=0
EXP_KEEP_RUNS=0
EXP_RESUME=1
EXP_SUMMARY_RERUN=1
EXP_FORCE_RECLONE=0
EXP_FORCE_REBOOTSTRAP=0
EXP_NOOV_QUIET_WAIT_MS=3000
EXP_OPENVIKING_INSTALL_MODE=auto

# Leave empty for the full formal benchmark.
EXP_SAMPLE_FILTER=0
EXP_GROUP_FILTER=
